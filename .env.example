# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=                          # leave blank for local polling mode

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: claude | openai | deepseek
LLM_PROVIDER=claude

# Optional: override the default model for your provider
# LLM_MAIN_MODEL=                              # defaults: claude-sonnet-4-6 | gpt-4o | deepseek-chat
# LLM_FAST_MODEL=                              # defaults: claude-haiku-4-5-20251001 | gpt-4o-mini | deepseek-chat

# Paste the API key for whichever provider you chose above
ANTHROPIC_API_KEY=                             # get at console.anthropic.com      (for claude)
OPENAI_API_KEY=                                # get at platform.openai.com        (for openai)
DEEPSEEK_API_KEY=                              # get at platform.deepseek.com      (for deepseek)

# ── Optional APIs ─────────────────────────────────────────────────────────────
# Nutritionix — accurate calorie/macro data from food text
# Free tier: 500 requests/day  |  developer.nutritionix.com
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# YouTube Data API v3 — exercise tutorial videos in workout plans
# Free tier: 10,000 units/day  |  console.cloud.google.com
YOUTUBE_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://drax:drax_pass@db:5432/drax_db
DATABASE_SYNC_URL=postgresql://drax:drax_pass@db:5432/drax_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
SECRET_KEY=change_this_in_production

# ── Fitness Defaults ──────────────────────────────────────────────────────────
DEFAULT_DAILY_WATER_ML=3000
DEFAULT_CALORIE_DEFICIT=500
