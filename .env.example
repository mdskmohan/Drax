# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Nutritionix API
NUTRITIONIX_APP_ID=your_nutritionix_app_id
NUTRITIONIX_API_KEY=your_nutritionix_api_key

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://fitbot:fitbot_pass@db:5432/fitbot_db
DATABASE_SYNC_URL=postgresql://fitbot:fitbot_pass@db:5432/fitbot_db

# Redis (for Celery)
REDIS_URL=redis://redis:6379/0

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
SECRET_KEY=your_secret_key_here_change_in_production

# User Goals (defaults, overridden per user)
DEFAULT_DAILY_WATER_ML=3000
DEFAULT_CALORIE_DEFICIT=500
