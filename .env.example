# ══════════════════════════════════════════════════════════════════
#  Drax — Environment Configuration
#  Copy this file to .env and fill in your keys.
#  Required fields are marked [REQUIRED]. Everything else is optional.
# ══════════════════════════════════════════════════════════════════

# ── Telegram [REQUIRED] ───────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# Leave blank for local development (polling mode)
# Set to your public HTTPS URL for production (webhook mode)
# Example: https://your-app.railway.app
TELEGRAM_WEBHOOK_URL=

# ── LLM Provider [REQUIRED — pick one] ───────────────────────────
# Options: claude | openai | deepseek
# Recommendation: claude (best quality) or deepseek (cheapest)
LLM_PROVIDER=claude

# Claude (Anthropic) — https://console.anthropic.com → API Keys
# Models used: claude-sonnet-4-6 (complex tasks), claude-haiku-4-5 (quick tasks)
# Cost: ~$0.25/1M tokens (Haiku), ~$3/1M tokens (Sonnet)
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com → API keys
# Models used: gpt-4o (complex tasks), gpt-4o-mini (quick tasks)
# Cost: ~$2.50/1M tokens (4o), ~$0.15/1M tokens (4o-mini)
OPENAI_API_KEY=

# DeepSeek — https://platform.deepseek.com → API Keys
# Model used: deepseek-chat (all tasks)
# Cost: ~$0.07/1M tokens (cheapest option)
DEEPSEEK_API_KEY=

# Optional: override the model for your chosen provider
# Leave blank to use the smart defaults above
# LLM_MAIN_MODEL=
# LLM_FAST_MODEL=

# ── Optional: Nutritionix (accurate calorie/macro data) ───────────
# Without this, Drax estimates nutrition via LLM (still works, less precise)
# Free tier: 500 API calls/day — https://developer.nutritionix.com
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# ── Optional: YouTube API (exercise tutorial videos in workouts) ──
# Without this, workout plans are generated without video links
# Free tier: 10,000 units/day — https://console.cloud.google.com
# Enable "YouTube Data API v3" → Create API Key
YOUTUBE_API_KEY=

# ── Database ──────────────────────────────────────────────────────
# For local Docker: use these defaults as-is
# For Railway/Render: they will set DATABASE_URL automatically — override it here
DATABASE_URL=postgresql+asyncpg://drax:drax_pass@db:5432/drax_db
DATABASE_SYNC_URL=postgresql://drax:drax_pass@db:5432/drax_db

# ── Redis ─────────────────────────────────────────────────────────
# For local Docker: use this default as-is
# For Railway/Render: they will set REDIS_URL automatically — override it here
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Change this to any random string in production
SECRET_KEY=change_this_to_a_random_string_in_production

# ── Fitness Defaults ──────────────────────────────────────────────
# These are overridden by each user's personal settings after onboarding
DEFAULT_DAILY_WATER_ML=3000
DEFAULT_CALORIE_DEFICIT=500
